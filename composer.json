{
    "name": "shekili/epoint",
    "description": "Epoint.az odenis sistemi",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "epoint",
        "gateway",
        "azerbaijan",
        "notification"
    ],
    "authors": [
        {
            "name": "Eflatun Memmedov",
            "email": "shekili.eno@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Shekili\\Epoint\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Shekili\\Epoint\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shekili\\Epoint\\EpointServiceProvider"
            ],
            "aliases": {
                "Epoint": "Shekili\\Epoint\\Facades\\Epoint"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}